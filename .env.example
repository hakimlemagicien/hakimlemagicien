# Paddle Checkout (required for card / Apple Pay approval)
VITE_PADDLE_CLIENT_TOKEN=
VITE_PADDLE_PRICE_TRANSFORM=
VITE_PADDLE_PRICE_PRO=
VITE_PADDLE_PRICE_VIP=

# Supabase (client — official project; copy from Supabase Dashboard → Settings → API)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Edge function secrets (Supabase Dashboard → Edge Functions → Secrets)
# SITE_URL=https://hakimlemagicien.com
# ADMIN_NOTIFICATION_EMAIL=support@hakimlemagicien.com
# RESEND_API_KEY=re_...   # required — get from https://resend.com (verify domain hakimlemagicien.com)
# EMAIL_FROM=Hakim Coaching <support@hakimlemagicien.com>
# SUPABASE_SERVICE_ROLE_KEY and SUPABASE_ANON_KEY are auto-injected in Supabase
