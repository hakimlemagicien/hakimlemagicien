# Paddle Checkout (required for card / Apple Pay approval)
VITE_PADDLE_CLIENT_TOKEN=
VITE_PADDLE_PRICE_TRANSFORM=
VITE_PADDLE_PRICE_PRO=
VITE_PADDLE_PRICE_VIP=

# Supabase (client — set via Lovable Cloud)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Edge function secrets (set in Supabase Dashboard → Edge Functions → Secrets)
# SITE_URL=https://your-domain.com
# ADMIN_NOTIFICATION_EMAIL=admin@example.com
# RESEND_API_KEY=re_...
# EMAIL_FROM=Hakim Coaching <noreply@your-domain.com>
# SUPABASE_SERVICE_ROLE_KEY and SUPABASE_ANON_KEY are auto-injected in Supabase
